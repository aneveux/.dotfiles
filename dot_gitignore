# ⚡ Global gitignore (core.excludesFile) — Linux + JVM/Node/Go + Editors + Claude/ccx

# 🐧 OS / Linux noise
*~
*.swp
*.swo
*.tmp
*.temp
.nfs*
.fuse_hidden*
.Trash-*
.directory

# 🍎 macOS junk (teammates on macOS leak these into repos)
.DS_Store
.AppleDouble
._*

# 🧠 Editors & IDEs
.idea/
*.iws
.vscode/
*.code-workspace

# ☕ JVM runtime noise
hs_err_pid*
replay_pid*

# 🌘 Eclipse / JDT-LS metadata (nvim-jdtls runs Eclipse JDT under the hood)
.project
.classpath
.factorypath
.settings/
# Safety-net catch-all; occasionally a project tracks logs on purpose.
*.log

# 📦 Build outputs (global safety net — NOT bare `build/`: it hides real source dirs)
target/
.gradle/
.quarkus/
node_modules/
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
# Go
*.test
*.out
# Hugo
public/
resources/_gen/
.hugo_build.lock
# Terraform
.terraform/
*.tfstate
*.tfstate.*

# 🤖 Claude / ccx (surgical: personal & regenerable only)
# Shareable per ccx design and intentionally NOT ignored: .claude/settings.json, rules/, commands/
.ccx/
.claude/settings.local.json
.claude/CLAUDE.md
.claude/plugin-map-cache.json
.claude/tmp/
.claude/cache/
.claude/.cc-writes/
.claudeignore
claude-debug.log
# MCP / Serena memory
.serena/

# 🔧 Local workflow artifacts
.quickflow/
*.reviews.json
.worktrees/
.stash/items.json.lock
