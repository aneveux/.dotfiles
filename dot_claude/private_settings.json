{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "model": "us.anthropic.claude-opus-4-6-v1",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-bash-security.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/repo-integrity-scanner.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/security-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-logger.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-bash-security.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-format.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-orientation.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/compact-reinjection.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-compact-snapshot.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/compact-reinjection.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cwd-profile.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stash-reminder.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-summary.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@2.2.15",
    "padding": 0
  },
  "enabledPlugins": {
    "safety-net@cc-marketplace": true,
    "antoine-voice@claude-secret-garden": true,
    "trellis@claude-garden": true,
    "thorn@claude-garden": true,
    "seed@claude-garden": true,
    "claude-stats@claude-secret-garden": true,
    "qf-inbox@claude-secret-garden": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-garden": {
      "source": {
        "source": "directory",
        "path": "/home/antoine/projects/claude-garden"
      }
    },
    "claude-secret-garden": {
      "source": {
        "source": "directory",
        "path": "/home/antoine/projects/claude-secret-garden"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skillListingBudgetFraction": 0.02,
  "skillOverrides": {
    "skill-creator:skill-creator": "user-invocable-only",
    "frontend-design:frontend-design": "off",
    "slack:slack-search": "user-invocable-only",
    "slack:slack-messaging": "user-invocable-only",
    "cloudbees-docs-dev:cloudbees-docs": "user-invocable-only",
    "seed:prompt-cultivation": "user-invocable-only",
    "claude-stats:claude-stats": "user-invocable-only",
    "jira-stats:jira-stats": "user-invocable-only",
    "agent-risk-checker:agent-risk-checker": "user-invocable-only",
    "claudecode-agent-registry:claudecode-agent-registry": "user-invocable-only"
  }
}
