{
  "model": "us.anthropic.claude-opus-4-6-v1",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claudeception-activator.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/repo-integrity-scanner.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/unicode-injection-detector.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prompt-injection-detector.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/security-check.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/dangerous-actions-blocker.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/antoine/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-logger.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/output-validator.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/output-secrets-scanner.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/home/antoine/.claude/hooks/gsd-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "cloudbees-context@cloudbees-marketplace": true,
    "safety-net@cc-marketplace": true,
    "cloudbees-docs-dev@cloudbees-dev-marketplace": true,
    "skill-creator@claude-plugins-official": true,
    "antoine-voice@claude-secret-garden": true,
    "bark@claude-garden": true,
    "trellis@claude-garden": true,
    "graft@claude-garden": true,
    "vine@claude-garden": true,
    "jdtls-lsp@claude-plugins-official": true,
    "jira-stats@claude-secret-garden": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-garden": {
      "source": {
        "source": "directory",
        "path": "/home/antoine/projects/claude-garden"
      }
    },
    "claude-secret-garden": {
      "source": {
        "source": "directory",
        "path": "/home/antoine/projects/claude-secret-garden"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
