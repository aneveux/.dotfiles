{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "model": "us.anthropic.claude-opus-4-6-v1",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-bash-security.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/repo-integrity-scanner.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/security-gate.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-bash-security.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pre-bash-security.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-logger.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/post-bash-security.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-format.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/session-summary.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "cloudbees-context@cloudbees-marketplace": true,
    "safety-net@cc-marketplace": true,
    "cloudbees-docs-dev@cloudbees-dev-marketplace": true,
    "skill-creator@claude-plugins-official": true,
    "antoine-voice@claude-secret-garden": true,
    "bark@claude-garden": true,
    "trellis@claude-garden": true,
    "graft@claude-garden": true,
    "vine@claude-garden": true,
    "jdtls-lsp@claude-plugins-official": true,
    "jira-stats@claude-secret-garden": true,
    "qf-inbox@claude-secret-garden": true,
    "thorn@claude-garden": true,
    "bloom@claude-garden": true,
    "frontend-design@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "seed@claude-garden": true,
    "claude-stats@claude-secret-garden": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-garden": {
      "source": {
        "source": "directory",
        "path": "/home/antoine/projects/claude-garden"
      }
    },
    "claude-secret-garden": {
      "source": {
        "source": "directory",
        "path": "/home/antoine/projects/claude-secret-garden"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
