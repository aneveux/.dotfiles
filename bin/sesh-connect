#!/usr/bin/env bash
# sesh-connect: wrapper around sesh connect that works outside tmux.
#
# Upstream bug: sesh runs `tmux attach-session` via os/exec.Command which
# captures stdout into a buffer. tmux detects it's not a tty and fails.
# Inside tmux, sesh uses switch-client instead (no tty needed), so it works.
#
# This wrapper lets sesh do session creation, then attaches directly.

set -euo pipefail

target="$1"

if [[ -n "${TMUX:-}" ]]; then
  exec sesh connect "$target"
fi

# Outside tmux: let sesh create the session (it will fail on attach, that's fine)
sesh connect "$target" 2>/dev/null || true

# Find the session sesh created (basename of path)
session_name="${target##*/}"

if tmux has-session -t "=$session_name" 2>/dev/null; then
  exec tmux attach-session -t "=$session_name"
elif tmux has-session -t "=$target" 2>/dev/null; then
  exec tmux attach-session -t "=$target"
else
  # Session wasn't created — create and attach directly
  expanded="${target/#\~/$HOME}"
  exec tmux new-session -s "$session_name" -c "$expanded"
fi
